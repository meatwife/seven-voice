# Discord bot token. Never commit your real token.
DISCORD_TOKEN=replace-me

# Discord user IDs. Use numeric snowflake IDs.
AGENT_USER_IDS=123456789012345678
HUMAN_USER_IDS=234567890123456789

# Optional: bind to one text channel, or leave blank and bind on join command.
TEXT_CHANNEL_ID=

# TTS voice, edge-tts voice name.
TTS_VOICE=en-US-AndrewMultilingualNeural

# STT / timing
WHISPER_MODEL=base.en
SILENCE_FLUSH_SEC=4.5
MIN_UTTERANCE_SEC=0.6
CHUNK_CHARS=700
